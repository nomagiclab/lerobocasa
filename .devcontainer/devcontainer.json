{
  "name": "lerobocasa-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "webPort": "6080"
    }
  },
  "appPort": [
    "6080:6080"
  ],
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "desktop-lite (noVNC)",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}